# Loaded by the UFC pipeline (Cron/ufc/*).
# Copy to Cron/.env and fill in real values. Cron/.env is gitignored.

# --- MySQL ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
UFC_DB=ufc

# --- The Odds API (https://the-odds-api.com) ---
# Used by Cron/ufc/oddsapi.py and Cron/ufc/bookmakers/sportsbook_api.py
ODDS_API_KEY=
