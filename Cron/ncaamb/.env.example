# Loaded by the NCAAMB pipeline (Cron/ncaamb/*).
# Copy to Cron/ncaamb/.env and fill in real values. Cron/ncaamb/.env is gitignored.

# --- MySQL ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
NCAAMB_DB=ncaamb

# --- The Odds API (https://the-odds-api.com) ---
# NCAAMB rotates two keys to stretch the free-tier request budget.
ODDS_API_KEY1=
ODDS_API_KEY2=
